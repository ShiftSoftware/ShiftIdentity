@using Pages.User
@using Pages.AccessTree
@using Pages.Department
@using Pages.Service
@using Pages.Company
@using Pages.CompanyBranch
@using Pages.Region
@using Pages.City
@using ShiftSoftware.ShiftIdentity.Dashboard.Blazor.Pages.Brand
@using ShiftSoftware.ShiftIdentity.Dashboard.Blazor.Pages.Country
@using ShiftSoftware.ShiftIdentity.Dashboard.Blazor.Pages.Team
@using Pages.CompanyCalendar

@inject ITypeAuthService TypeAuthService
@inject ShiftIdentityLocalizer Loc

<MudNavMenu>
    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(CountryList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Flag"
                          TypeAuthAction="ShiftIdentityActions.Regions">@Loc["Countries"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(RegionList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Map"
                          TypeAuthAction="ShiftIdentityActions.Regions">@Loc["Regions"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(CityList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.AccountBalance"
                          TypeAuthAction="ShiftIdentityActions.Cities">@Loc["Cities"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(BrandList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.LocalMall"
                          TypeAuthAction="ShiftIdentityActions.Brands">@Loc["Brands"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(DepartmentList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Dashboard"
                          TypeAuthAction="ShiftIdentityActions.Departments">@Loc["Departments"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(ServiceList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Checklist"
                          TypeAuthAction="ShiftIdentityActions.Services">@Loc["Services"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(CompanyList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Business"
                          TypeAuthAction="ShiftIdentityActions.Companies">@Loc["Companies"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(CompanyBranchList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.AddBusiness"
                          TypeAuthAction="ShiftIdentityActions.CompanyBranches">@Loc["Branches"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(CompanyCalendarMudPage)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.CalendarMonth"
                          TypeAuthAction="ShiftIdentityActions.CompanyCalendars">@Loc["Calendar"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(CompanyCalendarList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.EditCalendar"
                          TypeAuthAction="ShiftIdentityActions.CompanyCalendars">@Loc["Calendar Entries"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(AccessTreeList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.AccountTree"
                          TypeAuthAction="ShiftIdentityActions.AccessTrees">@Loc["Access Trees"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(UserList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.People"
                          TypeAuthAction="ShiftIdentityActions.Users">@Loc["Users"]</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{Constants.IdentityRoutePrefix}/{nameof(TeamList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Groups"
                          TypeAuthAction="ShiftIdentityActions.Teams">@Loc["Teams"]</AuthorizedMudNavLink>
</MudNavMenu>

@code {
    [Parameter] public bool isDrawerOpen { get; set; }
}