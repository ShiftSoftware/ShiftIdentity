@attribute [Authorize]
@layout Shared.DefaultLayout
@attribute [Route($"{Constants.IdentityRoutePreifix}/{nameof(CompanyList)}")]
@using ShiftSoftware.ShiftIdentity.Core.DTOs.Company;
@inject ShiftIdentityLocalizer Loc

<ShiftList EntitySet="@($"{Constants.IdentityRoutePreifix}Company")"
           Title="@Loc["Company List"]"
           T="CompanyListDTO"
           ComponentType="typeof(CompanyForm)"
           Dense
           DisableFilters
           TypeAuthAction="ShiftIdentityActions.Companies"
           EnableFilterPanel
           FilterPanelDefaultOpen
           EnableExport>

    <StringFilter Property="x => x.Name" Label="@Loc["Name"]" Operator="ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
    <StringFilter Property="x => x.IntegrationId" Label="@Loc["Integration ID"]" Operator="ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
    <EnumFilter Property="x => x.CompanyType" Label="@Loc["Company Type"]" lg="3" md="6" sm="12" xs="12" />
    <ForeignFilter Property="x => x.ParentCompanyID" Label="@Loc["Parent Company"]" DTOType="typeof(CompanyListDTO)" EntitySet="@($"{Constants.IdentityRoutePreifix}Company")" lg="3" md="6" sm="12" xs="12" />
    <DateTimeFilter Property="x => x.TerminationDate" Label="@Loc["TerminationDate"]" Operator="ShiftBlazor.Enums.ODataOperator.Equal" lg="3" md="6" sm="12" xs="12" />

    <PropertyColumnExtended Property="x => x.Name" Title="@Loc["Name"]" />
    <PropertyColumnExtended Property="x => x.LegalName" Title="@Loc["Legal Name"]" />
    <PropertyColumnExtended Property="x => x.ShortCode" Title="@Loc["Short Code"]" />
    <PropertyColumnExtended Property="x => x.IntegrationId" Title="@Loc["Integration ID"]" />

    <PropertyColumnExtended Title="@Loc["Company Type"]" Property="x => x.CompanyType"/>
    <PropertyColumnExtended Property="x => x.ParentCompanyName" Title="@Loc["Parent Company"]" />
    <PropertyColumnExtended Property="x => x.TerminationDate"Format="yyyy-MM-dd" Title="@Loc["TerminationDate"]" />
    <PropertyColumnExtended Property="x => x.DisplayOrder" Title="@Loc["Display Order"]" />
</ShiftList>