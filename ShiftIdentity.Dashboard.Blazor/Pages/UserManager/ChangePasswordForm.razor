@attribute [Authorize]
@attribute [Route($"{Constants.IdentityRoutePrefix}/{nameof(ChangePasswordForm)}")]

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using ShiftSoftware.ShiftEntity.Core.Extensions
@using ShiftSoftware.ShiftEntity.Model
@using ShiftSoftware.ShiftIdentity.Blazor.AuthRefresh
@using ShiftSoftware.ShiftIdentity.Core
@using ShiftSoftware.ShiftIdentity.Core.DTOs.User
@using ShiftSoftware.ShiftIdentity.Core.DTOs.UserManager
@using ShiftSoftware.ShiftIdentity.Core.Localization

@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inject HttpClient http
@inject ShiftIdentityLocalizer Loc
@inject IServiceProvider ServiceProvider

<MudPaper Elevation="25" Class="pa-5">
    @if (Enforce)
    {
        <MudAlert Severity="Severity.Info">@Loc["You must change your password"]</MudAlert>
    }

    <EditForm Model="@dto" OnValidSubmit="Save">
        <DataAnnotationsValidator />

        @if (!Enforce)
        {
            <MudTextField T="string" Label="@Loc["Current Password"]" @bind-Value="dto.CurrentPassword"
                          For="@(() => dto.CurrentPassword)" InputType="InputType.Password" />
        }

        <MudTextField T="string" Label="@Loc["New Password"]" HelperText="@Loc["Choose a strong password"]" @bind-Value="dto.NewPassword"
                      For="@(() => dto.NewPassword)" InputType="@newPasswordInputType"
                      Adornment="Adornment.End"
                      AdornmentIcon="@GetNewPasswordAdornmentIcon()"
                      OnAdornmentClick="@OnNewPasswordAdornmentClick"
                      AdornmentAriaLabel="@GetNewPasswordAdornmentAriaLabel()" />

        <MudTextField T="string" Label="@Loc["Confirm Password"]" @bind-Value="dto.ConfirmPassword"
                      For="@(() => dto.ConfirmPassword)" InputType="InputType.Password" />

        <br />
        <br />

        <MudGrid Justify="Justify.FlexEnd">
            @if (MudDialog is not null)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Cancel" OnClick="Cancel">@Loc["Cancel"]</MudButton>
            }

            <MudButton Color="Color.Primary" ButtonType="ButtonType.Submit">
                <MudIcon Icon="@Icons.Material.Filled.Save" />
                <MudText Style="padding:0 10px;">@Loc["Save"]</MudText>
            </MudButton>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    private ChangePasswordDTO dto = new ChangePasswordDTO();

    [CascadingParameter]
    protected IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public bool Enforce { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private bool showNewPassword = false;
    private InputType newPasswordInputType => showNewPassword ? InputType.Text : InputType.Password;

    private string GetNewPasswordAdornmentIcon()
    {
        if (string.IsNullOrEmpty(dto.NewPassword))
            return Icons.Material.Filled.VpnKey;
        else
            return showNewPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }
    private string GetNewPasswordAdornmentAriaLabel()
    {
        if (string.IsNullOrEmpty(dto.NewPassword))
            return "Generate Password";
        else
            return showNewPassword ? "Hide Password" : "Show Password";
    }
    private void OnNewPasswordAdornmentClick()
    {
        if (string.IsNullOrEmpty(dto.NewPassword))
        {
            dto.NewPassword = PasswordGenerator.GeneratePassword(8);
            showNewPassword = true;
        }
        else
        {
            showNewPassword = !showNewPassword;
        }
    }

    private void Cancel()
    {
        MudDialog?.Close();
    }

    private async Task Save()
    {
        if (Enforce)
            await CompleteChallengeAsync();
        else
            await ChangeWithCurrentPasswordAsync();
    }

    private async Task CompleteChallengeAsync()
    {
        // Forced flow: caller just logged in and holds the challenge token. Hand the new
        // password to /Auth/CompletePasswordChange via JwtRefreshStrategy, which replaces
        // the stored challenge with the full session token.
        var strategy = ServiceProvider.GetService(typeof(JwtRefreshStrategy)) as JwtRefreshStrategy;
        var stateProvider = ServiceProvider.GetService(typeof(ShiftAuthStateProvider)) as ShiftAuthStateProvider;
        if (strategy is null)
        {
            Snackbar.Add(Loc["Failed to change password"], Severity.Error);
            return;
        }

        var result = await strategy.CompletePasswordChangeAsync(new CompletePasswordChangeDTO
        {
            NewPassword = dto.NewPassword,
            ConfirmPassword = dto.ConfirmPassword,
        });

        if (!result.IsSuccess)
        {
            Snackbar.Add(result.ErrorMessage ?? Loc["Failed to change password"], Severity.Error);
            return;
        }

        if (stateProvider is not null && result.Claims is { Count: > 0 })
            stateProvider.NotifyUserAuthentication(result.Claims);

        if (MudDialog is not null)
        {
            MudDialog.Close();
            return;
        }

        var safeReturnUrl = !string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.IsLocalUrl() ? ReturnUrl : "/";
        NavManager.NavigateTo(safeReturnUrl, true);
    }

    private async Task ChangeWithCurrentPasswordAsync()
    {
        using var response = await http.PutAsJsonAsync("usermanager/ChangePassword", dto);

        if (!response.IsSuccessStatusCode)
        {
            var error = await response.Content.ReadFromJsonAsync<ShiftEntityResponse<UserDataDTO>>();
            var msg = string.IsNullOrWhiteSpace(error?.Message?.Title)
                ? error?.Message?.Body ?? Loc["Failed to change password"]
                : $"{error.Message.Title}: {error.Message.Body}";
            Snackbar.Add(msg, Severity.Error);
            return;
        }

        if (MudDialog is not null)
        {
            MudDialog.Close();
            return;
        }

        var safeReturnUrl = !string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.IsLocalUrl() ? ReturnUrl : "/";
        NavManager.NavigateTo(safeReturnUrl, true);
    }
}
