@attribute [Authorize]
@layout Shared.DefaultLayout
@attribute [Route($"{Constants.IdentityRoutePreifix}/{nameof(MfaForm)}")]
@inject ShiftModal ShiftModal
@inject MessageService Message
@inject AuthService AuthService
@inject NavigationManager NavManager
@inject IIdentityStore storageService
@inject ShiftIdentityLocalizer Loc
@inject AuthenticationStateProvider AuthenticationStateProvider
@using ShiftSoftware.ShiftIdentity.Blazor

<MudPaper Elevation="25" Class="pa-5">

    <EditForm Model="@dto" OnValidSubmit="VerifyMfa">
        <DataAnnotationsValidator />

        <MudText>@Loc["Enter the code from your two-factor authentication app or browser extension below"]</MudText>

        <MudTextField T="string" Label="@Loc["Code"]" @bind-Value="dto.Code"
                      For="@(() => dto.Code)" InputType="InputType.Password" />

        <br />
        <br />

        <MudGrid Justify="Justify.FlexEnd">
            @if (MudDialog is not null)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Cancel" OnClick="() => Cancel()">@Loc["Cancel"]</MudButton>
            }

            <MudButton Color="Color.Primary" ButtonType="ButtonType.Submit">
                <MudIcon Icon="@Icons.Material.Filled.Save" />
                <MudText Style="padding:0 10px;">@Loc["Verify"]</MudText>
            </MudButton>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    private MfaDTO dto = new ();

    [CascadingParameter]
    protected IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private Task Cancel()
    {
        if (MudDialog is not null)
            ShiftModal.Close(MudDialog);

        return Task.CompletedTask;
    }

    private async Task VerifyMfa()
    {
        var result = await AuthService.VerifyMfaAsync(dto);

        if (!result.IsSuccess)
        {
            Message.Error(result?.Data?.Message?.Body!, result?.Data?.Message?.Title);

            return;
        }

        await storageService.StoreTokenAsync(result?.Data?.Entity!);

        //Notify AuthenticationStateProvider and TypeAuth taht auth state has changed
        await AuthenticationStateProvider.GetAuthenticationStateAsync();


        if (MudDialog is not null)
        {
            ShiftModal.Close(MudDialog);
            return;
        }

        NavManager.NavigateTo(ReturnUrl ?? "/", true);
    }
}