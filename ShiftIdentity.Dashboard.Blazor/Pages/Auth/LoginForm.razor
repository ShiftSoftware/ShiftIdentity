@attribute [Route($"{Constants.IdentityRoutePreifix}/login")]
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout Shared.EmptyLayout

@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization;
@using Microsoft.Extensions.DependencyInjection
@using ShiftSoftware.ShiftIdentity.Blazor
@using ShiftSoftware.ShiftIdentity.Core.DTOs
@using ShiftSoftware.ShiftIdentity.Dashboard.Blazor.Pages.UserManager;

@inject ShiftIdentityDashboardBlazorOptions ShiftIdentityDashboardBlazorOptions
@inject Services.AuthService AuthService
@inject MessageService msgService
@inject IIdentityStore storageService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavManager
@inject ShiftIdentityLocalizer Loc
@inject IServiceProvider ServiceProvider

@*@inject Services.AuthService authService
@inject MessageService msgService
@inject Services.StorageService storageService
@inject TypeAuth.Blazor.Services.TypeAuthService TypeAuth*@

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="10" md="8" lg="6" xl="6">
        <MudPaper Class="pa-4">

            <br />
            <MudGrid Justify="Justify.Center">
                <MudItem xs="11" sm="11" md="10" lg="8" xl=6>
                    <MudImage Src="@ShiftIdentityDashboardBlazorOptions.LogoPath" Style="width:100%;" />
                </MudItem>
            </MudGrid>
            <br />
            <br />

            <EditForm Model="@loginDto" OnValidSubmit="Login">
                <DataAnnotationsValidator />
                <MudTextField T="string" Label="@Loc["Username"]" @bind-Value="loginDto.Username" For="@(() => loginDto.Username)" />

                <MudTextField T="string" Label="@Loc["Password"]" @bind-Value="loginDto.Password"
                              For="@(() => loginDto.Password)" InputType="InputType.Password" />

                <br />
                <MudButton Size="Size.Small"
                           Color="Color.Warning"
                           Href="@($"{Constants.IdentityRoutePreifix}/{nameof(SendResetPasswordLink)}")"
                           Variant="Variant.Text">
                    @Loc["Forgot Password?"]
                </MudButton>

                <br />
                <br />

                <MudGrid Justify="Justify.Center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">@Loc["Login"]</MudButton>
                </MudGrid>
            </EditForm>

            <br />
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    LoginDTO loginDto { get; set; } = new LoginDTO();

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationStateTask { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (authenticationStateTask != null)
        {
            var authState = await authenticationStateTask;

            //Return to home if user already logged-in
            if (authState?.User?.Identity?.IsAuthenticated ?? false)
            {
                NavManager.NavigateTo("/");
                return;
            }
        }

        // External hosting without cookie auth: redirect to external identity frontend (OAuth/PKCE flow)
        // When UseCookieAuth is true, the login form is shown and credentials are posted to /api/identity/login
        if (ShiftIdentityDashboardBlazorOptions.ShiftIdentityHostingType == ShiftIdentityHostingTypes.External
            && !ShiftIdentityDashboardBlazorOptions.UseCookieAuth)
        {
            var codeVerifierService = ServiceProvider.GetService<ShiftSoftware.ShiftIdentity.Blazor.Services.CodeVerifierService>();
            var identityOptions = ServiceProvider.GetService<ShiftSoftware.ShiftIdentity.Blazor.ShiftIdentityBlazorOptions>();

            if (codeVerifierService != null && identityOptions != null)
            {
                var codeChallenge = await codeVerifierService.GenerateCodeChallengeAsync();

                // During SSR, set the code verifier cookie directly on the user's response
                var httpContextAccessor = ServiceProvider.GetService<Microsoft.AspNetCore.Http.IHttpContextAccessor>();
                var codeVerifier = await codeVerifierService.LoadCodeVerifierAsync();
                if (httpContextAccessor?.HttpContext != null && codeVerifier != null)
                {
                    httpContextAccessor.HttpContext.Response.Cookies.Append("shift_code_verifier", codeVerifier, new Microsoft.AspNetCore.Http.CookieOptions
                    {
                        HttpOnly = true,
                        Secure = true,
                        SameSite = Microsoft.AspNetCore.Http.SameSiteMode.Lax,
                        MaxAge = TimeSpan.FromMinutes(10),
                    });
                }

                var queryStrings = new Dictionary<string, object?>
                {
                    { "AppId", identityOptions.AppId },
                    { "CodeChallenge", codeChallenge }
                };

                if (!string.IsNullOrWhiteSpace(ReturnUrl))
                    queryStrings.Add("ReturnUrl", ReturnUrl);

                var url = $"{(identityOptions.FrontEndBaseUrl.EndsWith('/') ? identityOptions.FrontEndBaseUrl : identityOptions.FrontEndBaseUrl + "/")}{Constants.IdentityRoutePreifix}/Auth/AuthCode";
                var uri = NavManager.GetUriWithQueryParameters(url, queryStrings);
                NavManager.NavigateTo(uri, true);
                return;
            }
        }
    }

    private async Task Login()
    {
        var loginResult = await this.AuthService.LoginAsync(loginDto);

        if (!loginResult.IsSuccess)
        {
            msgService.Error(loginResult?.Data?.Message?.Body!, loginResult?.Data?.Message?.Title);

            return;
        }

        var token = loginResult?.Data?.Entity;

        if (token != null)
        {
            await storageService.StoreTokenAsync(token);
        }

        //Notify AuthenticationStateProvider and TypeAuth that auth state has changed
        await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (token?.RequirePasswordChange ?? false)
        {
            var url = $"{Constants.IdentityRoutePreifix}/{nameof(ChangePasswordForm)}";

            var queryStrings = new Dictionary<string, object?>();
            queryStrings.Add("ReturnUrl", ReturnUrl ?? "/");
            queryStrings.Add("Enforce", true);

            var uri = NavManager.GetUriWithQueryParameters(url, queryStrings);

            NavManager.NavigateTo(uri);
            return;
        }

        var returnUrl = !String.IsNullOrWhiteSpace(ReturnUrl) ? ReturnUrl : "/";

        // Force reload so the browser picks up the auth cookie set by the server
        NavManager.NavigateTo(returnUrl, forceLoad: true);
    }
}