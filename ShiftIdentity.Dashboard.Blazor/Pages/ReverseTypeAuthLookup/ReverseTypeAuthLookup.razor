@attribute [Authorize]
@layout Shared.DefaultLayout

@attribute [Route($"{Constants.IdentityRoutePreifix}/{nameof(ReverseTypeAuthLookup)}")]

@using ShiftSoftware.ShiftIdentity.Core.DTOs.ReverseTypeAuthLookup
@using ShiftSoftware.ShiftIdentity.Dashboard.Blazor.Shared.ActionTree
@using ShiftSoftware.ShiftEntity.Model
@using Microsoft.JSInterop
@using System.Text
@using System.Text.Json

@inject Services.HttpService HttpService
@inject ShiftIdentityLocalizer Loc
@inject MessageService MessageService
@inject IJSRuntime JS

<style>
    /* Cap every column so no single long value (email, branch, name, ...) stretches the table.
       Overflowing text is truncated with an ellipsis; the full value is on the cell's title tooltip. */
    .reverse-lookup-table td,
    .reverse-lookup-table th {
        white-space: nowrap;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Chip columns get a little more room; ShiftChipDisplay collapses its own overflow into a "+N" chip. */
    .reverse-lookup-table .chip-cell {
        max-width: 260px;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h5">@Loc["Reverse TypeAuth Lookup"]</MudText>
        <MudText Typo="Typo.body2" Class="mt-2">
            @Loc["Click an access level on any action below to list all active users who have that access."]
        </MudText>
    </MudPaper>

    <ActionTree Tree="@emptyTree" PickerMode="true" OnActionPicked="OnActionPicked" />

</MudContainer>

<MudDialog @bind-Visible="resultsOpen" Options="dialogOptions">
    <TitleContent>
        @if (lastResult is not null)
        {
            <MudText Typo="Typo.h6">
                @lastDisplayName
            </MudText>
            <MudText Typo="Typo.caption">
                @Loc["Matching users"]: @lastResult.TotalMatchingUsers
                @if (lastResult.SuperAdminCount > 0)
                {
                    <span> · @Loc["includes {0} super-admin(s)", lastResult.SuperAdminCount]</span>
                }
                <span> · @Loc["Matching access trees"]: @lastResult.TotalMatchingAccessTrees</span>
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        @if (loading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (lastResult is null)
        {
            <MudAlert Severity="Severity.Info">@Loc["No results."]</MudAlert>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" @bind-ActivePanelIndex="activeTabIndex">
                <MudTabPanel Text="@($"{Loc["Users"]} ({lastResult.TotalMatchingUsers})")">
                    @if (lastResult.Users.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">@Loc["No users match this access."]</MudAlert>
                    }
                    else
                    {
                        <MudTable Items="lastResult.Users" Class="reverse-lookup-table" Dense="true" Hover="true" Striped="true"
                                  Virtualize="true" FixedHeader="true" Height="55vh">
                            <HeaderContent>
                                <MudTh>@Loc["ID"]</MudTh>
                                <MudTh>@Loc["Raw ID"]</MudTh>
                                <MudTh>@Loc["Full Name"]</MudTh>
                                <MudTh>@Loc["Username"]</MudTh>
                                <MudTh>@Loc["Email"]</MudTh>
                                <MudTh>@Loc["Branch"]</MudTh>
                                <MudTh>@Loc["Access Trees"]</MudTh>
                                <MudTh>@Loc["Granted By"]</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd title="@context.ID"><code>@context.ID</code></MudTd>
                                <MudTd title="@context.RawID"><code>@context.RawID</code></MudTd>
                                <MudTd title="@context.FullName">@context.FullName</MudTd>
                                <MudTd title="@context.Username">@context.Username</MudTd>
                                <MudTd title="@context.Email">@context.Email</MudTd>
                                <MudTd title="@context.CompanyBranch">@context.CompanyBranch</MudTd>
                                <MudTd Class="chip-cell">
                                    <ShiftChipDisplay T="ChipItem" Items="@AccessTreeChips(context)">
                                        <ChipTemplate Context="chip">
                                            <MudChip T="string" Color="chip.Color" Size="Size.Small">@chip.Label</MudChip>
                                        </ChipTemplate>
                                    </ShiftChipDisplay>
                                </MudTd>
                                <MudTd Class="chip-cell">
                                    <ShiftChipDisplay T="ChipItem" Items="@GrantedByChips(context)">
                                        <ChipTemplate Context="chip">
                                            <MudChip T="string" Color="chip.Color" Size="Size.Small">@chip.Label</MudChip>
                                        </ChipTemplate>
                                    </ShiftChipDisplay>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>

                <MudTabPanel Text="@($"{Loc["Access Trees"]} ({lastResult.TotalMatchingAccessTrees})")">
                    @if (lastResult.AccessTrees.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">@Loc["No access trees match this access."]</MudAlert>
                    }
                    else
                    {
                        <MudTable Items="lastResult.AccessTrees" Class="reverse-lookup-table" Dense="true" Hover="true" Striped="true"
                                  Virtualize="true" FixedHeader="true" Height="55vh">
                            <HeaderContent>
                                <MudTh>@Loc["ID"]</MudTh>
                                <MudTh>@Loc["Raw ID"]</MudTh>
                                <MudTh>@Loc["Name"]</MudTh>
                                <MudTh>@Loc["Assigned Users"]</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd title="@context.ID"><code>@context.ID</code></MudTd>
                                <MudTd title="@context.RawID"><code>@context.RawID</code></MudTd>
                                <MudTd title="@context.Name">@context.Name</MudTd>
                                <MudTd>@context.AssignedUserCount</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
            </MudTabs>
        }
    </DialogContent>
    <DialogActions>
        @if (CanExportActiveTab())
        {
            <MudButton OnClick="ExportActiveTab" StartIcon="@Icons.Material.Filled.Download" Color="Color.Primary">
                @Loc["Export CSV"]
            </MudButton>
        }
        <MudButton OnClick="CloseResults">@Loc["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly string emptyTree = "{}";

    private ReverseTypeAuthLookupResponseDTO? lastResult;
    private string? lastDisplayName;
    private bool loading;
    private bool resultsOpen;
    private int activeTabIndex;

    private readonly DialogOptions dialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Medium };

    private async Task OnActionPicked(ActionPickedEventArgs args)
    {
        lastDisplayName = args.DisplayName;
        lastResult = null;
        loading = true;
        resultsOpen = true;
        StateHasChanged();

        try
        {
            var qs = new List<string>
            {
                $"ActionPath={System.Web.HttpUtility.UrlEncode(args.ActionPath)}",
                $"Access={args.Access}",
                $"AnyDynamicRow={(args.AnyDynamicRow ? "true" : "false")}",
            };

            if (!string.IsNullOrWhiteSpace(args.DynamicId))
                qs.Add($"DynamicId={System.Web.HttpUtility.UrlEncode(args.DynamicId)}");

            var url = $"ReverseTypeAuthLookup?{string.Join("&", qs)}";

            var response = await HttpService.GetAsync<ShiftEntityResponse<ReverseTypeAuthLookupResponseDTO>>(url);

            if (!response.IsSuccess)
            {
                MessageService.Error(response.Data?.Message?.Body ?? response.ErrorMessage ?? Loc["Request failed"]);
                resultsOpen = false;
            }
            else
            {
                lastResult = response.Data?.Entity;
            }
        }
        catch (Exception ex)
        {
            MessageService.Error(ex.Message);
            resultsOpen = false;
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    // Tab 0 = Users, Tab 1 = Access Trees.
    private bool CanExportActiveTab()
        => lastResult is not null
           && (activeTabIndex == 0 ? lastResult.Users.Count > 0 : lastResult.AccessTrees.Count > 0);

    private Task ExportActiveTab()
        => activeTabIndex == 0 ? ExportUsersCsv() : ExportAccessTreesCsv();

    private async Task ExportUsersCsv()
    {
        if (lastResult is null || lastResult.Users.Count == 0)
            return;

        var sb = new StringBuilder();
        sb.AppendLine("ID,RawID,Username,FullName,Email,Branch,IsSuperAdmin,AccessTrees,GrantedBy");
        foreach (var u in lastResult.Users)
        {
            var grantedBy = u.IsSuperAdmin
                ? "Super Admin"
                : string.Join("; ", (u.GrantedBySelf ? new[] { "Self" } : Array.Empty<string>()).Concat(u.GrantingAccessTrees));

            sb.Append(CsvField(u.ID)).Append(',')
              .Append(CsvField(u.RawID)).Append(',')
              .Append(CsvField(u.Username)).Append(',')
              .Append(CsvField(u.FullName)).Append(',')
              .Append(CsvField(u.Email)).Append(',')
              .Append(CsvField(u.CompanyBranch)).Append(',')
              .Append(u.IsSuperAdmin ? "true" : "false").Append(',')
              .Append(CsvField(string.Join("; ", u.AccessTrees))).Append(',')
              .Append(CsvField(grantedBy))
              .Append('\n');
        }

        await DownloadCsv(sb.ToString(), "reverse-typeauth-users");
    }

    private async Task ExportAccessTreesCsv()
    {
        if (lastResult is null || lastResult.AccessTrees.Count == 0)
            return;

        var sb = new StringBuilder();
        sb.AppendLine("ID,RawID,Name,AssignedUsers");
        foreach (var t in lastResult.AccessTrees)
        {
            sb.Append(CsvField(t.ID)).Append(',')
              .Append(CsvField(t.RawID)).Append(',')
              .Append(CsvField(t.Name)).Append(',')
              .Append(t.AssignedUserCount.ToString())
              .Append('\n');
        }

        await DownloadCsv(sb.ToString(), "reverse-typeauth-access-trees");
    }

    private async Task DownloadCsv(string body, string filenamePrefix)
    {
        // \uFEFF BOM so Excel opens UTF-8 correctly.
        var csv = "\uFEFF" + body;
        var csvLiteral = JsonSerializer.Serialize(csv);
        var filename = $"{filenamePrefix}-{DateTime.Now:yyyyMMdd-HHmmss}.csv";

        var script = $@"(function() {{
            const csv = {csvLiteral};
            const blob = new Blob([csv], {{ type: 'text/csv;charset=utf-8;' }});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = '{filename}';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            setTimeout(() => URL.revokeObjectURL(url), 1000);
        }})();";

        await JS.InvokeVoidAsync("eval", script);
    }

    private static string CsvField(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return "";
        if (value.IndexOfAny(new[] { ',', '"', '\n', '\r' }) < 0)
            return value;
        return "\"" + value.Replace("\"", "\"\"") + "\"";
    }

    private void CloseResults()
    {
        resultsOpen = false;
    }

    private sealed record ChipItem(string Label, Color Color);

    // All access trees assigned to the user (plus a Super Admin chip when applicable).
    private List<ChipItem> AccessTreeChips(ReverseTypeAuthLookupUserDTO user)
    {
        var chips = new List<ChipItem>();

        if (user.IsSuperAdmin)
            chips.Add(new ChipItem(Loc["Super Admin"], Color.Error));

        foreach (var tree in user.AccessTrees)
            chips.Add(new ChipItem(tree, Color.Primary));

        return chips;
    }

    // The source(s) that actually grant the looked-up action: Super Admin, Self, and/or specific trees.
    private List<ChipItem> GrantedByChips(ReverseTypeAuthLookupUserDTO user)
    {
        if (user.IsSuperAdmin)
            return new List<ChipItem> { new(Loc["Super Admin"], Color.Error) };

        var chips = new List<ChipItem>();

        if (user.GrantedBySelf)
            chips.Add(new ChipItem(Loc["Self"], Color.Info));

        foreach (var tree in user.GrantingAccessTrees)
            chips.Add(new ChipItem(tree, Color.Primary));

        return chips;
    }
}
