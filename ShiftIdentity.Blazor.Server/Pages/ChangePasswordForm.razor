@attribute [Route(Constants.CookieChangePasswordPath)]
@attribute [Authorize]

@using System.Security.Claims
@using ShiftSoftware.ShiftIdentity.Blazor.Server.Services
@using ShiftSoftware.ShiftIdentity.Core
@using ShiftSoftware.ShiftIdentity.Core.DTOs.UserManager
@using ShiftSoftware.ShiftIdentity.Core.Localization
@using ShiftSoftware.ShiftEntity.Core.Extensions

@inject ICookieChangePasswordHandler ChangePasswordHandler
@inject NavigationManager NavManager
@inject ShiftIdentityLocalizer Loc

<PageTitle>@Loc["Change Password"]</PageTitle>

<div style="max-width:420px;margin:6rem auto;padding:2rem;border:1px solid #e0e0e0;border-radius:8px;font-family:Roboto,sans-serif;">
    <h1 style="margin-top:0;">@Loc["Change Password"]</h1>

    @if (isChallenge)
    {
        <div style="margin-bottom:1rem;padding:.75rem;background:#fff4e5;color:#7a4d00;border-radius:4px;">
            @Loc["You must change your password"]
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div role="alert" style="margin-bottom:1rem;padding:.75rem;background:#fde7e9;color:#9b1c1c;border-radius:4px;">
            @errorMessage
        </div>
    }

    <EditForm Model="Input" method="post" OnValidSubmit="HandleSubmitAsync" FormName="change-password">
        <DataAnnotationsValidator />

        @if (!isChallenge)
        {
            <div style="margin-bottom:1rem;">
                <label for="current-password" style="display:block;margin-bottom:.25rem;">@Loc["Current Password"]</label>
                <InputText id="current-password" type="password" @bind-Value="Input.CurrentPassword" autocomplete="current-password"
                           style="width:100%;padding:.5rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;" />
                <ValidationMessage For="() => Input.CurrentPassword" style="color:#9b1c1c;font-size:.85rem;" />
            </div>
        }

        <div style="margin-bottom:1rem;">
            <label for="new-password" style="display:block;margin-bottom:.25rem;">@Loc["New Password"]</label>
            <InputText id="new-password" type="password" @bind-Value="Input.NewPassword" autocomplete="new-password"
                       style="width:100%;padding:.5rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;" />
            <ValidationMessage For="() => Input.NewPassword" style="color:#9b1c1c;font-size:.85rem;" />
        </div>

        <div style="margin-bottom:1rem;">
            <label for="confirm-password" style="display:block;margin-bottom:.25rem;">@Loc["Confirm Password"]</label>
            <InputText id="confirm-password" type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password"
                       style="width:100%;padding:.5rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;" />
            <ValidationMessage For="() => Input.ConfirmPassword" style="color:#9b1c1c;font-size:.85rem;" />
        </div>

        @if (!isChallenge)
        {
            <div style="margin-bottom:1rem;">
                <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                    <InputCheckbox @bind-Value="Input.SignOutOtherSessions" />
                    @Loc["Sign out all other devices"]
                </label>
            </div>
        }

        <button type="submit"
                style="width:100%;padding:.6rem;background:#1976d2;color:#fff;border:0;border-radius:4px;font-size:1rem;cursor:pointer;">
            @Loc["Change Password"]
        </button>
    </EditForm>

    @if (isChallenge)
    {
        @* Challenge mode: the user holds a partial cookie (RequirePasswordChange) and the
           normal app chrome isn't reachable — logout is the only escape. Posted as a separate
           form per the form-post-only cookie-mutation contract (Phase 1.3). *@
        <form method="post" action="/api/identity/logout" style="margin-top:.75rem;">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@Constants.CookieLoginPath" />
            <button type="submit"
                    style="width:100%;padding:.6rem;background:transparent;color:#1976d2;border:1px solid #1976d2;border-radius:4px;font-size:1rem;cursor:pointer;">
                @Loc["Logout"]
            </button>
        </form>
    }
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private ChangePasswordInputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery(Name = Constants.ReturnUrlParameter)]
    private string? ReturnUrl { get; set; }

    private string? errorMessage;
    private bool isChallenge;

    protected override void OnInitialized()
    {
        Input ??= new();
        // The cookie carries the RequirePasswordChange claim when the user is in challenge
        // state — i.e. they just logged in but haven't been issued a full session. In that
        // case, skip the current-password prompt (they entered it during login) and call
        // CompletePasswordChange, which upgrades the cookie to a full session.
        var claim = HttpContext.User.FindFirstValue(ShiftIdentityClaims.RequirePasswordChange);
        isChallenge = bool.TryParse(claim, out var v) && v;
    }

    private async Task HandleSubmitAsync()
    {
        if (Input.NewPassword != Input.ConfirmPassword)
        {
            errorMessage = Loc["New Password and Confirm Password do not match"];
            return;
        }

        CookieChangePasswordResult result;
        if (isChallenge)
        {
            var dto = new CompletePasswordChangeDTO
            {
                NewPassword = Input.NewPassword,
                ConfirmPassword = Input.ConfirmPassword,
            };
            result = await ChangePasswordHandler.CompletePasswordChangeAsync(dto, HttpContext);
        }
        else
        {
            var dto = new ChangePasswordDTO
            {
                CurrentPassword = Input.CurrentPassword,
                NewPassword = Input.NewPassword,
                ConfirmPassword = Input.ConfirmPassword,
                SignOutOtherSessions = Input.SignOutOtherSessions,
            };
            result = await ChangePasswordHandler.ChangePasswordAsync(dto, HttpContext);
        }

        if (!result.Succeeded)
        {
            errorMessage = result.ErrorMessage ?? Loc["Password change failed"];
            return;
        }

        var safeReturnUrl = !string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.IsLocalUrl() ? ReturnUrl : "/";
        NavManager.NavigateTo(safeReturnUrl);
    }

    private sealed class ChangePasswordInputModel
    {
        public string CurrentPassword { get; set; } = "";

        [Required(ErrorMessage = "New password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your new password")]
        public string ConfirmPassword { get; set; } = "";

        // Default checked: changing your password signs out your other devices unless you opt out.
        public bool SignOutOtherSessions { get; set; } = true;
    }
}
