@attribute [Route(Constants.CookieLoginPath)]
@attribute [AllowAnonymous]

@using ShiftSoftware.ShiftIdentity.Blazor.Server.Services
@using ShiftSoftware.ShiftIdentity.Core
@using ShiftSoftware.ShiftIdentity.Core.DTOs
@using ShiftSoftware.ShiftIdentity.Core.Localization
@using ShiftSoftware.ShiftEntity.Core.Extensions

@inject ICookieLoginHandler LoginHandler
@inject NavigationManager NavManager
@inject ShiftIdentityLocalizer Loc

<PageTitle>@Loc["Login"]</PageTitle>

<div style="max-width:420px;margin:6rem auto;padding:2rem;border:1px solid #e0e0e0;border-radius:8px;font-family:Roboto,sans-serif;">
    <h1 style="margin-top:0;">@Loc["Login"]</h1>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div role="alert" style="margin-bottom:1rem;padding:.75rem;background:#fde7e9;color:#9b1c1c;border-radius:4px;">
            @errorMessage
        </div>
    }

    <EditForm Model="Input" method="post" OnValidSubmit="HandleLoginAsync" FormName="login">
        <DataAnnotationsValidator />

        <div style="margin-bottom:1rem;">
            <label for="username" style="display:block;margin-bottom:.25rem;">@Loc["Username"]</label>
            <InputText id="username" @bind-Value="Input.Username" autocomplete="username"
                       style="width:100%;padding:.5rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;" />
            <ValidationMessage For="() => Input.Username" style="color:#9b1c1c;font-size:.85rem;" />
        </div>

        <div style="margin-bottom:1rem;">
            <label for="password" style="display:block;margin-bottom:.25rem;">@Loc["Password"]</label>
            <InputText id="password" type="password" @bind-Value="Input.Password" autocomplete="current-password"
                       style="width:100%;padding:.5rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;" />
            <ValidationMessage For="() => Input.Password" style="color:#9b1c1c;font-size:.85rem;" />
        </div>

        <button type="submit"
                style="width:100%;padding:.6rem;background:#1976d2;color:#fff;border:0;border-radius:4px;font-size:1rem;cursor:pointer;">
            @Loc["Login"]
        </button>
    </EditForm>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private LoginInputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    private string? ReturnUrl { get; set; }

    private string? errorMessage;

    protected override void OnInitialized()
    {
        Input ??= new();
    }

    private async Task HandleLoginAsync()
    {
        var loginDto = new LoginDTO { Username = Input.Username, Password = Input.Password };
        var result = await LoginHandler.LoginAsync(loginDto, HttpContext);

        if (!result.Succeeded)
        {
            errorMessage = result.ErrorMessage ?? Loc["Login failed"];
            return;
        }

        var safeReturnUrl = !string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.IsLocalUrl() ? ReturnUrl : "/";

        // The cookie is now written to the current response. Redirecting causes the browser
        // to issue a fresh request that carries the cookie, so the next render is authenticated.
        if (result.RequirePasswordChange)
        {
            var changePasswordUrl = $"{Constants.CookieChangePasswordPath}?{Constants.ReturnUrlParameter}={Uri.EscapeDataString(safeReturnUrl)}";
            NavManager.NavigateTo(changePasswordUrl);
            return;
        }

        NavManager.NavigateTo(safeReturnUrl);
    }

    private sealed class LoginInputModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = "";
    }
}
